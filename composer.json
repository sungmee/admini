{
    "name": "sungmee/admini",
    "description": "Admini is a simply auth and post (cms) publication Laravel packages for company homepage or micro blog.",
    "keywords": ["packages", "laravel", "admin", "cms"],
    "type": "package",
    "license": "MIT",
    "homepage": "https://github.com/sungmee/admini",
    "authors": [
        {
            "name": "SUNGMEE",
            "email": "mo@lxooo.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Sungmee\\Admini\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sungmee\\Admini\\ServiceProvider"
            ],
            "aliases": {
                "Admin": "Sungmee\\Admini\\Facade"
            }
        }
    }
}